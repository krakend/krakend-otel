{
    "version": 3,
    "name": "Front KrakenD",
    "port": 44444,
    "cache_ttl": "3600s",
    "timeout": "2500ms",
    "host": [ "http://127.0.0.1:44445/" ],
    "endpoints": [
        {
            "endpoint": "/fake/{something}",
            "concurrent_calls": 3,
            "backend": [
                {
                    "url_pattern": "/middle_fake/{something}"
                }
            ]
        },
        {
            "endpoint": "/combination/{id}",
            "backend": [
                {
                    "url_pattern": "/middle_combination/{id}",
                    "group": "front_1"
                },
                {
                    "url_pattern": "/middle_combination/{id}",
                    "group": "front_2"
                }
            ]
        }
    ],
    "extra_config": {
        "telemetry/opentelemetry": {
            "service_name": "krakend_frontend_service",
            "layers": {
                "router": {
                    "metrics": true,
                    "traces": true,
                    "disable_propagation": false
                },
                "pipe": {
                    "metrics": true,
                    "traces": true
                }, 
                "backend": {
                    "metrics": {
                        "stage": true,
                        "round_trip": true,
                        "read_payload": true,
                        "static_attributes": {
                            "my_metric_attr": "my_metric_val"
                        }
                    },
                    "traces": {
                        "stage": true,
                        "round_trip": true,
                        "read_payload": true,
                        "static_attributes": {
                            "my_trace_attr": "my_trace_val" 
                        }
                    }
                }
            },
            "exporters": {
                "local_prometheus": {
                    "kind": "prometheus",
                    "config": {
                        "port": 9091,
                        "process_metrics": true,
                        "go_metrics": true
                    }
                },
                "local_tempo": {
                    "kind": "opentelemetry",
                    "config": {
                        "port": 4317,
                        "use_http": false
                    }
                },
                "local_jaeger": {
                    "kind": "opentelemetry",
                    "config": {
                        "port": 5317,
                        "use_http": false
                    }
                }
            },
            "metric_providers": [
                "local_prometheus"
            ],
            "metric_reporting_period": 1,
            "trace_providers": [
                "local_tempo",
                "local_jaeger"
            ],
            "trace_sample_rate": 1,
            "extra": {
                "custom": "extra",
                "future_expansion": true
            }
        }
    }
}
