{
    "version": 3,
    "name": "Back KrakenD",
    "port": 44446,
    "cache_ttl": "3600s",
    "timeout": "2500ms",
    "host": [ "http://krakend_back:44446/" ],
    "endpoints": [
        {
            "endpoint": "/back_fake/{something}",
            "method": "GET",
            "concurrent_calls": 3,
            "backend": [
                {
                    "url_pattern": "/__debug/{something}",
                    "mapping": {
                        "message": "backend1"
                    }
                },
                {
                    "url_pattern": "/__debug/{something}/{something}",
                    "mapping": {
                        "message": "backend2"
                    }
                }
            ]
        },
        {
            "endpoint": "/back_combination/{id}",
            "backend": [
                {
                    "host": [
                        "https://jsonplaceholder.typicode.com"
                    ],
                    "url_pattern": "/posts?userId={id}",
                    "is_collection": true,
                    "mapping": {
                        "collection": "posts"
                    }
                },
                {
                    "host": [
                        "https://jsonplaceholder.typicode.com"
                    ],
                    "url_pattern": "/users/{id}",
                    "mapping": {
                        "email": "personal_email"
                    }
                }
            ]
        }
    ],
    "extra_config": {
        "telemetry/opentelemetry": {
            "service_name": "krakend_frontend_service",
            "layers": {
                "router": {
                    "metrics": true,
                    "traces": true,
                    "disable_propagation": false
                },
                "pipe": {
                    "metrics": true,
                    "traces": true
                }, 
                "backend": {
                    "metrics": {
                        "stage": true,
                        "round_trip": true,
                        "read_payload": true,
                        "detailed_connection": true,
                        "static_attributes": {
                            "my_metric_attr": "my_metric_val"
                        }
                    },
                    "traces": {
                        "stage": true,
                        "round_trip": true,
                        "read_payload": true,
                        "detailed_connection": true,
                        "static_attributes": {
                            "my_trace_attr": "my_trace_val" 
                        }
                    }
                }
            },
            "exporters": {
                "local_prometheus": {
                    "kind": "prometheus",
                    "config": {
                        "port": 9090,
                        "process_metrics": true,
                        "go_metrics": true
                    }
                },
                "local_tempo": {
                    "kind": "opentelemetry",
                    "config": {
                        "host": "tempo",
                        "port": 4317,
                        "use_http": false
                    }
                },
                "local_jaeger": {
                    "kind": "opentelemetry",
                    "config": {
                        "host": "jaeger",
                        "port": 5317,
                        "use_http": false
                    }
                }
            },
            "metric_providers": [
                "local_prometheus"
            ],
            "metric_reporting_period": 1,
            "trace_providers": [
                "local_tempo",
                "local_jaeger"
            ],
            "trace_sample_rate": 1,
            "extra": {
                "custom": "extra",
                "future_expansion": true
            }
        }
    }
}
